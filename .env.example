PORT=3000
SESSION_SECRET=replace_me_with_a_long_random_string

# Option A (quick start): paste a short-lived access token.
STRAVA_ACCESS_TOKEN=replace_me

# OAuth (required for login flow)
STRAVA_CLIENT_ID=replace_me
STRAVA_CLIENT_SECRET=replace_me
STRAVA_REDIRECT_URI=http://localhost:3000/auth/strava/callback
